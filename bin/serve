#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT_DIR"

# Prevent common local crashes when an old Jekyll process still owns ports.
for port in 4000 35729; do
  pids="$(lsof -ti tcp:"$port" -sTCP:LISTEN 2>/dev/null || true)"
  if [ -n "$pids" ]; then
    echo "Stopping process(es) on port $port: $pids"
    kill $pids || true
  fi
done

# Run Jekyll as a child so we can turn external TERM into a graceful INT.
bundle exec jekyll serve --livereload --host 0.0.0.0 --port 4000 --livereload-port 35729 &
child_pid=$!

cleanup() {
  if kill -0 "$child_pid" 2>/dev/null; then
    kill -INT "$child_pid" 2>/dev/null || true
    wait "$child_pid" || true
  fi
  exit 0
}

trap cleanup TERM INT
wait "$child_pid"